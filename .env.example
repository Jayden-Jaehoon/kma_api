# KMA API 인증키 (https://apihub.kma.go.kr/)
# 동일한 키를 사용해도 되고, 시스템별로 다른 키를 사용해도 됩니다.

# ASOS (지상관측) 시스템 인증키
asos_authKey=YOUR_ASOS_AUTH_KEY_HERE

# Fusion Weather (융합기상) 시스템 인증키
fusion_weather_authKey=YOUR_FUSION_WEATHER_AUTH_KEY_HERE

# 동적 데이터 저장 경로 (raw/interim/output)
# 미설정 시 프로젝트 내 data/ 폴더에 저장됩니다.
 USION_DATA_ROOT=E:\kma
